@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.AI
@attribute [Authorize]
@implements IAsyncDisposable
@inject DndMcpAICsharpFun.Features.Chat.DndChatService ChatService
@inject IJSRuntime JS

<div class="chat-container">
    @if (_sendError is not null)
    {
        <div class="chat-error-banner" role="alert">
            <span>⚠ @_sendError</span>
            <button class="banner-dismiss" @onclick="() => _sendError = null">✕</button>
        </div>
    }
    <div class="messages" id="messages-container">
        @foreach (var msg in ChatService.History)
        {
            <div class="message @(msg.Role == ChatRole.User ? "user" : "assistant")">
                <div class="bubble">@msg.Text</div>
            </div>
        }
        @if (_loading)
        {
            <div class="message assistant">
                <div class="bubble loading">Thinking...</div>
            </div>
        }
    </div>

    <div class="input-row">
        <textarea @bind="_input"
                  @bind:event="oninput"
                  @onkeydown="OnKeyDown"
                  disabled="@_loading"
                  rows="1"
                  placeholder="Ask about D&D rules, spells, monsters..."></textarea>
        <label class="web-search-toggle">
            <input type="checkbox" @bind="_webSearchEnabled" disabled="@_loading" />
            Search web
        </label>
        <button @onclick="Send" disabled="@_loading">Send</button>
        <button class="clear-conversation" @onclick="ClearConversation" disabled="@_loading" title="Clear conversation">Clear</button>
    </div>
</div>

@code {
    private string _input = "";
    private string? _sendError;
    private bool _loading;
    private bool _webSearchEnabled;
    private bool _scrollRequired;
    private CancellationTokenSource _cts = new();

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
    }

    protected override async Task OnInitializedAsync()
    {
        await ChatService.LoadHistoryAsync();
        if (ChatService.History.Count == 0)
            ChatService.History.Add(new ChatMessage(
                ChatRole.Assistant,
                "Hello, adventurer! Ask me anything about D&D rules, spells, monsters, and lore."));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _scrollRequired)
        {
            _scrollRequired = false;
            await JS.InvokeVoidAsync("scrollToBottom", "messages-container");
        }
    }

    private async Task Send()
    {
        var msg = _input.Trim();
        if (string.IsNullOrEmpty(msg) || _loading) return;

        _sendError = null;
        _input = "";
        _loading = true;
        _scrollRequired = true;
        StateHasChanged();

        try
        {
            var ok = await ChatService.SendAsync(msg, _webSearchEnabled, _cts.Token);
            if (!ok) _sendError = "Couldn't send message. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ClearConversation()
    {
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm", "Clear conversation? This permanently deletes all messages.");
        if (!confirmed) return;

        await ChatService.ClearAsync();
        _sendError = null;
        ChatService.History.Add(new ChatMessage(
            ChatRole.Assistant,
            "Hello, adventurer! Ask me anything about D&D rules, spells, monsters, and lore."));
        _scrollRequired = true;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await Send();
    }


}
