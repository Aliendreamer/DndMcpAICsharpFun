{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Debug",
        "System.Net.Http.HttpClient": "Information",
        "DndMcpAICsharpFun": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/service.log",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 7,
          "fileSizeLimitBytes": 1073741824,
          "buffered": true,
          "shared": false
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "Qdrant": {
    "Host": "qdrant",
    "Port": 6334
  },
  "Ollama": {
    "BaseUrl": "ollama:11434"
  },
  "Ingestion": {
    "BooksPath": "./books"
  },
  "Postgres": {
    "Host": "localhost"
  },
  "MinerU": {
    "ServiceUrl": "http://mineru:8000"
  },
  "Admin": {
    "ApiKey": "devXXXdev"
  },
  "OpenTelemetry": {
    "Enabled": true
  },
  "Mcp": {
    "ApiKey": "devMcpKey"
  }
}