{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/service.log",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 7,
          "fileSizeLimitBytes": 1073741824,
          "buffered": false,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "AllowedHosts": "*",
  "Qdrant": {
    "Host": "qdrant",
    "Port": 6334,
    "ApiKey": null,
    "VectorSize": 1024,
    "BlocksCollectionName": "dnd_blocks",
    "EntitiesCollectionName": "dnd_entities",
    "HybridAlpha": 0.5
  },
  "Ollama": {
    "BaseUrl": "http://ollama:11434",
    "EmbeddingModel": "mxbai-embed-large",
    "ChatModel": "qwen3:8b"
  },
  "MinerU": {
    "ServiceUrl": "http://mineru:8000",
    "Backend": "pipeline",
    "Method": "ocr",
    "ConversionTimeoutMinutes": 120
  },
  "EntityExtraction": {
    "CanonicalDirectory": "/books/canonical",
    "SchemasDirectory": "Schemas/canonical",
    "MaxRetriesPerEntity": 3,
    "MaxOutputTokensPerEntity": 16384,
    "ProgressLogIntervalSeconds": 60,
    "CheckpointIntervalCandidates": 100,
    "ConversionCacheDirectory": "/books/conversion-cache",
    "ExamplesDirectory": "Schemas/examples",
    "MaxTokensPerChunk": 2000
  },
  "EntityIngestion": {
    "CanonicalDirectory": "/books/canonical"
  },
  "Ingestion": {
    "BooksPath": "/books",
    "MaxChunkTokens": 512,
    "OverlapTokens": 64
  },
  "Postgres": {
    "Host": "postgres",
    "Port": 5432,
    "Database": "dnd",
    "Username": "dnd",
    "Password": "dnd"
  },
  "Retrieval": {
    "ScoreThreshold": 0.5,
    "MaxTopK": 20
  },
  "Reranker": {
    "Enabled": true,
    "ModelPath": "models",
    "ModelUrl": "https://huggingface.co/cross-encoder/ms-marco-MiniLM-L-6-v2/resolve/main/onnx/model.onnx",
    "VocabUrl": "https://huggingface.co/cross-encoder/ms-marco-MiniLM-L-6-v2/resolve/main/vocab.txt",
    "TopN": 5
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "dnd-mcp-api"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:5101"
      }
    }
  },
  "Mcp": {
    "ApiKey": ""
  },
  "McpClient": {
    "Url": "http://localhost:5101/mcp",
    "ApiKey": ""
  },
  "RateLimit": {
    "MessagesPerMinute": 10,
    "RequestsPerMinute": 60
  },
  "Chat": {
    "Persona": "companion",
    "PersonasDirectory": "Config/personas"
  },
  "SearXNG": {
    "Url": "http://searxng:8080",
    "MaxResults": 5,
    "AllowedDomains": [
      "dndbeyond.com",
      "5etools.com",
      "reddit.com",
      "enworld.org",
      "roll20.net",
      "sageadvice.eu"
    ]
  }
}