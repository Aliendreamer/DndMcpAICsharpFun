{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Qdrant": {
    "Host": "qdrant",
    "Port": 6334,
    "ApiKey": null,
    "VectorSize": 768,
    "CollectionName": "dnd_chunks"
  },
  "Ollama": {
    "BaseUrl": "http://ollama:11434",
    "EmbeddingModel": "nomic-embed-text",
    "ExtractionModel": "llama3.2"
  },
  "Ingestion": {
    "BooksPath": "/books",
    "DatabasePath": "/data/ingestion.db",
    "MinPageCharacters": 100,
    "MaxChunkTokens": 512,
    "OverlapTokens": 64,
    "EmbeddingBatchSize": 2
  },
  "Retrieval": {
    "ScoreThreshold": 0.5,
    "MaxTopK": 20
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "dnd-mcp-api"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:5101"
      }
    }
  }
}