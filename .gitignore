# .gitignore — DndMcpAICsharpFun (.NET 10 + Blazor + Docker + pnpm)
# Trimmed from the stock `dotnet new gitignore`; only rules relevant to this repo remain.

# --- Project data (books/ PDFs are ignored; hand-authored canonical JSON is tracked) ---
/books/*
!/books/.gitkeep
!/books/canonical/
/books/canonical/*
!/books/canonical/.gitkeep
!/books/canonical/*.json
# Transient entity-extraction checkpoints (deleted on success)
books/canonical/*.progress.json
books/canonical/*.progress.errors.json
models/
data/spike/*.json
*.db

# --- Secrets / local overrides ---
.env
.env.*
!.env.example
docker-compose.override.yml

# --- .NET build output ---
[Bb]in/
[Oo]bj/
artifacts/
[Tt]est[Rr]esult*/
TestResults/
*.binlog
*.nupkg
*.snupkg
project.lock.json

# --- Coverage ---
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml

# --- User / IDE files ---
*.user
*.suo
*.userosscache
*.userprefs
.vs/
.idea/
*.sln.iml
*.code-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp

# --- Tooling scratch ---
node_modules/
__pycache__/
*.pyc
.worktrees/
.superpowers/
.mineru-spike/
.claude/scheduled_tasks.lock
# Playwright MCP writes snapshots/console/screenshots here — never commit
.playwright-mcp/
# Live-smoke screenshots saved to the repo root (transient UI-verification artifacts)
/*-desktop-*.png
/*-mobile-*.png

# --- Logs ---
*.log
logs/**

# --- OS cruft ---
.DS_Store
._*
Thumbs.db
[Dd]esktop.ini
TestResults/
logs/