# Copy to .env (git-ignored) and set real values for local `docker compose up`.
# These keys are required — compose fails fast if they are unset (no weak defaults are committed).

# Admin API key — guards /admin/* and /metrics (sent as the X-Admin-Api-Key header).
ADMIN_API_KEY=

# MCP API key — must match on both the server (Mcp__ApiKey) and the loopback client (McpClient__ApiKey).
MCP_API_KEY=

# Optional overrides
# ASPNETCORE_ENVIRONMENT=Development
# POSTGRES_PASSWORD=dnd
