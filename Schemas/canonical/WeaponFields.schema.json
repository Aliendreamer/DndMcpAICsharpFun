{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "WeaponFields",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "category": {
      "type": "string"
    },
    "weaponType": {
      "type": "string"
    },
    "costCp": {
      "type": "integer",
      "format": "int32"
    },
    "weightLb": {
      "type": "number",
      "format": "double"
    },
    "damage": {
      "$ref": "#/definitions/DamagePart"
    },
    "range": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/definitions/AttackRange"
        }
      ]
    },
    "properties": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "DamagePart": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dice": {
          "type": "string"
        },
        "average": {
          "type": "integer",
          "format": "int32"
        },
        "type": {
          "type": "string"
        },
        "versatile": {
          "type": [
            "null",
            "string"
          ]
        }
      }
    },
    "AttackRange": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "normal": {
          "type": "integer",
          "format": "int32"
        },
        "long": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        }
      }
    }
  }
}