        "ref": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "MonsterAction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "$ref": "#/definitions/ActionType"
        },
        "summary": {
          "type": "string"
        },
        "attackBonus": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "reach": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "range": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/definitions/AttackRange"
            }
          ]
        },
        "targets": {
          "type": [
            "null",
            "string"
          ]
        },
        "damage": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/DamagePart"
          }
        },
        "recharge": {
          "type": [
            "null",
            "string"
          ]
        },
        "save": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/definitions/SaveBlock"
            }
          ]
        }
      }
    },
    "ActionType": {
      "type": "string",
      "description": "",
      "x-enumNames": [
        "Multiattack",
        "MeleeWeaponAttack",
        "RangedWeaponAttack",
        "MeleeOrRangedWeaponAttack",
        "Save",
        "Passive",
        "Other"
      ],
      "enum": [
        "Multiattack",
        "MeleeWeaponAttack",
        "RangedWeaponAttack",
        "MeleeOrRangedWeaponAttack",
        "Save",
        "Passive",
        "Other"
      ]
    },
    "AttackRange": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "normal": {
          "type": "integer",
          "format": "int32"
