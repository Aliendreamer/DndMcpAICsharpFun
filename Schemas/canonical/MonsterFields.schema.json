        "ability": {
          "type": [
            "null",
            "string"
          ]
        },
        "ritualCasting": {
          "type": "boolean"
        },
        "preparation": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/definitions/SpellPreparation"
            }
          ]
        },
        "cantripsKnownByLevel": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "integer",
            "format": "int32"
          }
        },
        "spellsKnownByLevel": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "integer",
            "format": "int32"
          }
        },
        "spellList": {
          "type": [
            "null",
            "string"
          ]
        },
        "spellSlotsByLevel": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/SpellSlotsRow"
          }
        },
        "pactSlotsByLevel": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/PactSlotRow"
          }
        }
      }
    },
    "SpellcastingType": {
      "type": "string",
      "description": "",
      "x-enumNames": [
        "Full",
        "Half",
        "Third",
        "Pact",
        "Innate",
        "None"
      ],
      "enum": [
        "Full",
        "Half",
        "Third",
        "Pact",
        "Innate",
        "None"
      ]
    },
    "SpellPreparation": {
      "type": "string",
      "description": "",
      "x-enumNames": [
        "Spellbook",
        "Known",
        "Prepared"
      ],
      "enum": [
        "Spellbook",
        "Known",
        "Prepared"
      ]
    },
    "SpellSlotsRow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "integer",
          "format": "int32"
        },
        "slotsByLevel": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "int32"
          }
        }
      }
    },
    "PactSlotRow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "integer",
          "format": "int32"
        },
        "slots": {
          "type": "integer",
          "format": "int32"
        },
        "slotLevel": {
          "type": "integer",
          "format": "int32"
        }
      }
