        "dexterity": {
          "type": "integer",
          "format": "int32"
        },
        "constitution": {
          "type": "integer",
          "format": "int32"
        },
        "intelligence": {
          "type": "integer",
          "format": "int32"
        },
        "wisdom": {
          "type": "integer",
          "format": "int32"
        },
        "charisma": {
          "type": "integer",
          "format": "int32"
        }
      }
