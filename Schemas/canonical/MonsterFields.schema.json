        "cost": {
          "type": "integer",
          "format": "int32"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "LairBlock": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "initiativeCount": {
          "type": "integer",
          "format": "int32"
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/LairActionEntry"
          }
        },
        "regionalEffects": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RegionalEffect"
          }
        }
      }
    },
    "LairActionEntry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string"
        }
      }
    },
    "RegionalEffect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string"
        }
      }
    }
