      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/definitions/SpellcastingBlock"
        }
      ]
    },
    "legendaryActions": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/definitions/LegendaryBlock"
        }
      ]
    },
    "lairActions": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/definitions/LairBlock"
