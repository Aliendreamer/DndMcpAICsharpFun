  "definitions": {
    "ArmorClass": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": "integer",
          "format": "int32"
        },
        "source": {
          "type": [
            "null",
            "string"
          ]
        }
      }
    },
    "HitPoints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "average": {
          "type": "integer",
          "format": "int32"
