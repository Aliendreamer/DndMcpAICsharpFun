{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "SpellFields",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "level": {
      "type": "integer",
      "format": "int32"
    },
    "school": {
      "type": "string"
    },
    "castingTime": {
      "type": "string"
    },
    "range": {
      "type": "string"
    },
    "components": {
      "$ref": "#/definitions/SpellComponents"
    },
    "duration": {
      "type": "string"
    },
    "ritual": {
      "type": "boolean"
    },
    "concentration": {
      "type": "boolean"
    },
    "description": {
      "type": "string"
    },
    "atHigherLevels": {
      "type": [
        "null",
        "string"
      ]
    },
    "classes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "damageTypes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "SpellComponents": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "v": {
          "type": "boolean"
        },
        "s": {
          "type": "boolean"
        },
        "m": {
          "type": "boolean"
        },
        "material": {
          "type": [
            "null",
            "string"
          ]
        }
      }
    }
  }
}