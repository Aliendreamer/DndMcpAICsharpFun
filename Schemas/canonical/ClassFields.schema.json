{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "$comment": "// SCHEMA-OVERRIDE: hand-authored 5etools-aligned schema; do not regenerate from C# class",
  "title": "ClassFields",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "hd": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "number": { "type": "integer", "format": "int32" },
        "faces": { "type": "integer", "format": "int32" }
      }
    },
    "proficiency": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    },
    "startingProficiencies": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "startingEquipment": {
      "type": ["array", "null"],
      "items": { "type": "object", "additionalProperties": true }
    },
    "classFeatures": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "classFeature": { "type": "string" },
          "level": { "type": "integer", "format": "int32" }
        }
      }
    },
    "subclassTitle": { "type": ["null", "string"] },
    "spellcastingAbility": { "type": ["null", "string"] },
    "casterProgression": { "type": ["null", "string"] },
    "preparedSpells": { "type": ["null", "string"] },
    "entries": {
      "type": ["array", "null"],
      "items": { "type": ["string", "object"] }
    },
    "multiclassing": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  }
}
