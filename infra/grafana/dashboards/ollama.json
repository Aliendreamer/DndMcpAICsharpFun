          "expr": "histogram_quantile(0.99, rate(ollama_load_duration_seconds_bucket[${__interval}]))",
          "legendFormat": "p99 load {{model}}"
        }
      ],
      "title": "Model Load Time p99",
      "type": "timeseries"
    }
