@page "/campaigns/{Id:long}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using DndMcpAICsharpFun.Features.Campaigns
@attribute [Authorize]
@inject CampaignRepository CampaignRepo
@inject HeroRepository HeroRepo
@inject NoteRepository NoteRepo
@inject NavigationManager Nav
@inject AuthenticationStateProvider Auth

<PageTitle>@(_campaign?.Name ?? "Campaign")</PageTitle>

@if (_campaign is null)
{
    <p>Loading...</p>
}
else
{
    <div class="campaign-detail">
        <nav><a href="/campaigns">← Campaigns</a></nav>
        <h1>@_campaign.Name</h1>
        @if (!string.IsNullOrEmpty(_campaign.Description))
        {
            <p class="campaign-desc">@_campaign.Description</p>
        }

        <h2>Party</h2>
        <div class="hero-roster">
            @foreach (var hero in _heroes)
            {
                var sheet = hero.LatestSnapshot?.Sheet;
                <div class="hero-card" @onclick="() => GoToHero(hero.Id)">
                    <strong>@hero.Name</strong>
                    @if (sheet is not null)
                    {
                        <span>@sheet.Class @(string.IsNullOrEmpty(sheet.Subclass) ? "" : $"({sheet.Subclass})") · Lv @sheet.Level</span>
                        <span>HP @sheet.CurrentHitPoints / @sheet.MaxHitPoints · AC @sheet.ArmorClass</span>
                    }
                </div>
            }
        </div>

        @if (_showAddHero)
        {
            <div class="add-hero-form">
                <input @bind="_newHeroName" placeholder="Hero name" />
                @if (!string.IsNullOrEmpty(_addHeroError))
                {
                    <p class="error">@_addHeroError</p>
                }
                <button @onclick="AddHeroAsync">Add</button>
                <button @onclick="CancelAddHero">Cancel</button>
            </div>
        }
        else
        {
            <button @onclick="ShowAddHero">+ Add Hero</button>
        }

        <DiceRollerPanel CampaignId="Id" UserId="_userId" OnLogged="RefreshLog" />

        <EncounterPanel CampaignId="Id" UserId="_userId" OnSaved="RefreshLog" />

        <CampaignLog @ref="_log" CampaignId="Id" UserId="_userId" />

        <h2>Notes</h2>
        <div class="notes-list">
            @foreach (var note in _notes)
            {
                <div class="note-card">
                    @if (_editingNoteId == note.Id)
                    {
                        <input @bind="_editTitle" placeholder="Title" />
                        <textarea @bind="_editContent" placeholder="Write a note..." rows="3"></textarea>
                        @if (!string.IsNullOrEmpty(_editNoteError))
                        {
                            <p class="error">@_editNoteError</p>
                        }
                        <button @onclick="() => SaveNoteEditAsync(note.Id)">Save</button>
                        <button @onclick="CancelEditNote">Cancel</button>
                    }
                    else
                    {
                        <div class="note-head">
                            <strong>@note.Title</strong>
                            <span class="note-actions">
                                <button class="note-edit" title="Edit" @onclick="() => BeginEditNote(note)">✎</button>
                                <button class="note-del" title="Delete" @onclick="() => DeleteNoteAsync(note.Id)">✕</button>
                            </span>
                        </div>
                        <p class="note-body">@note.Content</p>
                        <span class="note-time">@note.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                    }
                </div>
            }
            @if (_notes.Count == 0)
            {
                <p class="muted">No notes yet.</p>
            }
        </div>

        @if (_showAddNote)
        {
            <div class="add-note-form">
                <input @bind="_noteTitle" placeholder="Title" />
                <textarea @bind="_noteContent" placeholder="Write a note..." rows="3"></textarea>
                @if (!string.IsNullOrEmpty(_addNoteError))
                {
                    <p class="error">@_addNoteError</p>
                }
                <button @onclick="AddNoteAsync">Save</button>
                <button @onclick="CancelAddNote">Cancel</button>
            </div>
        }
        else
        {
            <button @onclick="() => _showAddNote = true">+ Add Note</button>
        }
    </div>
}

@code {
    [Parameter] public long Id { get; set; }

    private Campaign? _campaign;
    private List<Hero> _heroes = [];
    private long _userId;
    private CampaignLog? _log;
    private bool _showAddHero;
    private string _newHeroName = "";
    private string _addHeroError = "";

    private List<Note> _notes = [];
    private bool _showAddNote;
    private string _noteTitle = "";
    private string _noteContent = "";
    private string _addNoteError = "";

    private long? _editingNoteId;
    private string _editTitle = "";
    private string _editContent = "";
    private string _editNoteError = "";

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        _userId = long.Parse(state.User.FindFirst(ClaimTypes.NameIdentifier)!.Value);
        _campaign = await CampaignRepo.GetByIdAsync(Id, _userId);
        if (_campaign is null)
        {
            Nav.NavigateTo("/campaigns");
            return;
        }
        _heroes = await HeroRepo.GetByCampaignAsync(Id);
        _notes = await NoteRepo.GetByCampaignAsync(Id);
    }

    private void GoToHero(long heroId) => Nav.NavigateTo($"/campaigns/{Id}/heroes/{heroId}");

    private async Task RefreshLog()
    {
        if (_log is not null)
            await _log.RefreshAsync();
    }
    private void ShowAddHero() => _showAddHero = true;
    private void CancelAddHero() { _showAddHero = false; _addHeroError = ""; }

    private async Task AddHeroAsync()
    {
        if (string.IsNullOrWhiteSpace(_newHeroName))
        {
            _addHeroError = "Name is required.";
            return;
        }
        var heroId = await HeroRepo.CreateAsync(Id, _newHeroName.Trim());
        Nav.NavigateTo($"/campaigns/{Id}/heroes/{heroId}");
    }

    private void CancelAddNote() { _showAddNote = false; _noteTitle = ""; _noteContent = ""; _addNoteError = ""; }

    private async Task AddNoteAsync()
    {
        if (string.IsNullOrWhiteSpace(_noteTitle))
        {
            _addNoteError = "Title is required.";
            return;
        }
        await NoteRepo.CreateAsync(_userId, Id, _noteTitle.Trim(), _noteContent.Trim());
        _notes = await NoteRepo.GetByCampaignAsync(Id);
        CancelAddNote();
    }

    private async Task DeleteNoteAsync(long noteId)
    {
        await NoteRepo.DeleteAsync(noteId, Id);
        _notes = await NoteRepo.GetByCampaignAsync(Id);
    }

    private void BeginEditNote(Note note)
    {
        _editingNoteId = note.Id;
        _editTitle = note.Title;
        _editContent = note.Content;
        _editNoteError = "";
    }

    private void CancelEditNote()
    {
        _editingNoteId = null;
        _editTitle = "";
        _editContent = "";
        _editNoteError = "";
    }

    private async Task SaveNoteEditAsync(long noteId)
    {
        if (string.IsNullOrWhiteSpace(_editTitle))
        {
            _editNoteError = "Title is required.";
            return;
        }
        await NoteRepo.UpdateAsync(noteId, Id, _editTitle.Trim(), _editContent.Trim());
        _notes = await NoteRepo.GetByCampaignAsync(Id);
        CancelEditNote();
    }
}
