@inject DndMcpAICsharpFun.Features.Encounters.EncounterDesignService EncounterSvc
@inject DndMcpAICsharpFun.Features.Campaigns.CampaignLogRepository LogRepo
@using DndMcpAICsharpFun.Features.Encounters
@using DndMcpAICsharpFun.Features.Campaigns

<div class="encounter-panel">
    <h2>Encounter Builder</h2>

    <div class="encounter-controls">
        <label>
            Difficulty
            <select @bind="_difficulty">
                <option value="@Difficulty.Easy">Easy</option>
                <option value="@Difficulty.Medium">Medium</option>
                <option value="@Difficulty.Hard">Hard</option>
                <option value="@Difficulty.Deadly">Deadly</option>
            </select>
        </label>

        <label>
            Edition
            <select @bind="_edition">
                <option value="@DndVersion.Edition2014">2014</option>
                <option value="@DndVersion.Edition2024">2024</option>
            </select>
        </label>

        <label>
            Theme
            <input type="text" @bind="_theme" @bind:event="oninput" placeholder="e.g. undead (optional)" />
        </label>

        <button type="button" class="btn btn--primary" @onclick="BuildAsync">Build</button>
    </div>

    @if (_error is not null)
    {
        <p class="error">@_error</p>
    }

    @if (_built is not null)
    {
        var a = _built.Assessment;
        <div class="encounter-result">
            <p>
                <strong>@a.Difficulty</strong> · Total XP @a.TotalMonsterXp · Adjusted XP @a.AdjustedXp
            </p>
            <p>Monsters: @string.Join(", ", a.Monsters.Select(m => m.Name))</p>
            @if (!_built.FullyMatched && !string.IsNullOrWhiteSpace(_built.Note))
            {
                <p class="muted">@_built.Note</p>
            }

            @if (CampaignId > 0)
            {
                <div class="encounter-save-row">
                    <input type="text" @bind="_label" @bind:event="oninput" placeholder="Label (optional)" />
                    <label><input type="checkbox" @bind="_hidden" /> Hidden</label>
                    <button type="button" class="btn btn--primary" @onclick="SaveAsync">Save to log</button>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public long CampaignId { get; set; }
    [Parameter] public long UserId { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback<BuiltEncounter> OnBuilt { get; set; }
    [Parameter] public IReadOnlyList<int>? PartyLevels { get; set; }

    private Difficulty _difficulty = Difficulty.Medium;
    private DndVersion _edition = DndVersion.Edition2014;
    private string _theme = "";
    private string _label = "";
    private bool _hidden;
    private BuiltEncounter? _built;
    private string? _error;

    private async Task BuildAsync()
    {
        try
        {
            _built = await EncounterSvc.BuildForUserAsync(
                UserId,
                CampaignId,
                partyLevels: PartyLevels,
                _difficulty,
                _edition,
                string.IsNullOrWhiteSpace(_theme) ? null : _theme,
                crLte: null,
                crGte: null,
                default);
            _error = null;

            if (_built is not null)
                await OnBuilt.InvokeAsync(_built);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _built = null;
        }
    }

    private async Task SaveAsync()
    {
        if (_built is null) return;

        var a = _built.Assessment;
        var payload = new EncounterLogPayload(
            a.Difficulty.ToString(),
            a.TotalMonsterXp,
            a.AdjustedXp,
            _built.PartyLevels,
            a.Monsters.Select(m => new EncounterMonsterLog(m.Id, m.Name, m.Cr, m.Xp)).ToList(),
            _built.FullyMatched,
            _built.Note);

        try
        {
            await LogRepo.AddEncounterAsync(
                UserId,
                CampaignId,
                payload,
                string.IsNullOrWhiteSpace(_label) ? null : _label,
                _hidden);
            await OnSaved.InvokeAsync();
            _built = null;
            _label = "";
            _hidden = false;
            _error = null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
