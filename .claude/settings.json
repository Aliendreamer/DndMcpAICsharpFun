{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Bash(dotnet *)",
      "Bash(pnpm *)",
      "Bash(openspec *)",
      "Bash(git worktree *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git add *)",
      "Bash(git stash *)",
      "Bash(git rebase *)",
      "Bash(git commit *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(docker *)",
      "Bash(docker compose *)",
      "mcp__serena__*",
      "mcp__plugin_serena_serena__*"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D*)",
      "Bash(git branch --delete --force*)",
      "Read(./Config/**)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "csharp-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "dotnet-ai@dotnet-agent-skills": true,
    "dotnet-aspnet@dotnet-agent-skills": true,
    "dotnet@dotnet-agent-skills": true,
    "dotnet-data@dotnet-agent-skills": true,
    "dotnet-diag@dotnet-agent-skills": true,
    "dotnet-msbuild@dotnet-agent-skills": true,
    "dotnet-nuget@dotnet-agent-skills": true,
    "dotnet-template-engine@dotnet-agent-skills": true,
    "dotnet-test@dotnet-agent-skills": true,
    "dotnet-upgrade@dotnet-agent-skills": true
  },
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd",
        "--open-web-dashboard",
        "false"
      ]
    }
  },
  "extraKnownMarketplaces": {
    "dotnet-agent-skills": {
      "source": {
        "source": "github",
        "repo": "dotnet/skills"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "registry.yarnpkg.com",
        "registry.npmjs.org",
        "*.npmjs.org",
        "github.com",
        "codeload.github.com",
        "*.githubusercontent.com",
        "pypi.org",
        "files.pythonhosted.org",
        "api.nuget.org",
        "*.nuget.org",
        "nuget.org",
        "dist.nuget.org",
        "localhost",
        "127.0.0.1"
      ]
    },
    "filesystem": {
      "denyRead": [
        ".env",
        ".env.*",
        "Config/appsettings.json",
        "Config/appsettings.*.json"
      ],
      "allowWrite": [
        "/usr/local/share/.yarn-global",
        "~/.npm",
        "~/.cache",
        "~/.local/share/pnpm",
        "/var/run/docker.sock"
      ]
    }
  }
}